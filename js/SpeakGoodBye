// STEP 6: Wrap the entire contents inside an IIFE
(function(window) {

  // STEP 7: Creating an object byeSpeaker
  var byeSpeaker = {};

  // Private variable
  var speakWord = "Good Bye";

  // STEP 8: Method speak apply for the object
  byeSpeaker.speak = function(name) {
    console.log(speakWord + " " + name);
  };

  // STEP 9: Making the object globally available
  window.byeSpeaker = byeSpeaker;

})(window);
